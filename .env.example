# WebGuard RF - Environment Configuration
# Copy to .env and fill in values

# Application
APP_NAME=WebGuard RF
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.2.254:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=webguard
DB_PASSWORD=your_db_password
DB_NAME=webguard_rf
USE_DATABASE=true
# Apply Alembic migrations automatically when the API starts (requires alembic.ini + MySQL)
RUN_ALEMBIC_ON_STARTUP=true

# Database (PostgreSQL alternative)
# DATABASE_URL=postgresql://user:password@localhost:5432/webguard_rf

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Storage
DATA_DIR=./data
MODELS_DIR=./models
UPLOAD_MAX_SIZE_MB=500

# ML Defaults
DEFAULT_N_ESTIMATORS=200
DEFAULT_MAX_DEPTH=30
DEFAULT_RANDOM_STATE=42

# Security
BCRYPT_ROUNDS=12
JWT_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/webguard.log
