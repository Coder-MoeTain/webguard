# -------------------------
# Environment & Virtual Env
# -------------------------
.env
.env.local
.env.*.local
.venv/
venv/
env/
ENV/

# -------------------------
# Python
# -------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec

# -------------------------
# Node.js
# -------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn-integrity

# -------------------------
# IDE & Editors
# -------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Cursor
.cursor/

# -------------------------
# Data & Models (large files)
# -------------------------
data/*.parquet
data/*.csv
models/*.joblib
!data/.gitkeep
!models/.gitkeep

# -------------------------
# Logs
# -------------------------
logs/
*.log
*.log.*

# -------------------------
# OS
# -------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

